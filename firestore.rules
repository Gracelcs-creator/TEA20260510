rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Primitives
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Admins Collection
    match /admins/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // MenuItems Collection
    function isValidMenuItem(data) {
      return data.keys().hasAll(['nameZh', 'nameEn', 'priceM', 'priceL', 'category', 'isAvailable', 'createdAt', 'updatedAt'])
        && data.keys().size() == 8
        && data.nameZh is string && data.nameZh.size() > 0 && data.nameZh.size() <= 100
        && data.nameEn is string && data.nameEn.size() <= 100
        && data.priceM is number && data.priceM >= 0
        && data.priceL is number && data.priceL >= 0
        && data.category is string && data.category.size() > 0 && data.category.size() <= 50
        && data.isAvailable is bool
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /menuItems/{menuItemId} {
      allow get: if isValidId(menuItemId);
      allow list: if true; // Public menu
      allow create: if true
        && isValidId(menuItemId) 
        && isValidMenuItem(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if true
        && isValidId(menuItemId) 
        && isValidMenuItem(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
      allow delete: if isValidId(menuItemId);
    }

    // Orders Collection
    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'items', 'status', 'totalAmount', 'createdAt', 'updatedAt'])
        && data.keys().size() == 6
        && data.customerName is string && data.customerName.size() > 0 && data.customerName.size() <= 100
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50 // max 50 items
        && data.status is string && data.status in ['pending', 'processing', 'completed', 'cancelled']
        && data.totalAmount is number && data.totalAmount >= 0
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /orders/{orderId} {
      allow get: if isValidId(orderId);
      allow list: if true;
      
      allow create: if true
        && isValidId(orderId) 
        && isValidOrder(incoming())
        && incoming().status == 'pending'
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if true
        && isValidId(orderId) 
        && isValidOrder(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
    }
  }
}
